# Backend API
# Simulator/emulator on the same machine: use 10.0.2.2 (Android) or localhost (iOS)
# Physical device: use your machine's local IP (e.g. http://192.168.1.x:8000/api/v1)
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# Supabase — Dashboard → Settings → API
# EXPO_PUBLIC_SUPABASE_URL      → Project URL (https://xxxx.supabase.co)
# EXPO_PUBLIC_SUPABASE_ANON_KEY → anon / public key (safe to expose in the app bundle)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-from-supabase-dashboard
