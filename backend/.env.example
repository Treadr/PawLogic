# Database Configuration
# Docker Compose (docker compose up): DATABASE_URL is overridden automatically — leave as-is
# Local dev without Docker: change host from "db" to "localhost" and port to 5433
DATABASE_URL=postgresql+asyncpg://PawLogic_DB:PPaaPA55!!word@db:5432/PawLogic

# Supabase
# Cloud project (recommended): replace values from Supabase Dashboard → Settings → API
#   SUPABASE_URL       → Project URL (https://xxxx.supabase.co)
#   SUPABASE_JWT_SECRET → Settings → API → JWT Settings → JWT Secret
#   SUPABASE_SERVICE_KEY → service_role key (keep secret — never expose to clients)
# Local Supabase CLI (supabase start): use the values below as-is
SUPABASE_URL=https://xxdvjwkahfslfozqcnwl.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard
SUPABASE_SERVICE_KEY=your-service-role-key-from-supabase-dashboard

# Anthropic Claude API
# Required for AI insights and BIP generation; app runs without it but AI features are disabled
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Redis
# Docker Compose: overridden automatically — leave as-is
# Local dev without Docker: change "redis" to "localhost"
REDIS_URL=redis://redis:6379/0

# Application
ENVIRONMENT=development
LOG_LEVEL=DEBUG
# Include all origins that will call the API (web frontend on 3000, Expo on 8081/19006)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:19006"]
