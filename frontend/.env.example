# Backend API — must match the port uvicorn/docker-compose exposes
VITE_API_URL=http://localhost:8000/api/v1

# Supabase — Dashboard → Settings → API
# VITE_SUPABASE_URL      → Project URL (https://xxxx.supabase.co)
# VITE_SUPABASE_ANON_KEY → anon / public key (safe to expose in browser)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-from-supabase-dashboard
